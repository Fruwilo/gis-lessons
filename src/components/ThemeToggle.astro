---
// ====================================================
// ThemeToggle.astro — кнопка переключения темы
// Три режима по кругу: светлая → тёмная → системная
// ====================================================
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Переключить тему"
  title="Переключить тему"
  class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-colors"
>
  <!-- Иконка "светлая" (солнце) -->
  <svg data-theme-icon="light" hidden xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
  </svg>
  <!-- Иконка "тёмная" (луна) -->
  <svg data-theme-icon="dark" hidden xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
  </svg>
  <!-- Иконка "системная" (монитор) -->
  <svg data-theme-icon="system" hidden xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect width="20" height="14" x="2" y="3" rx="2" />
    <path d="M8 21h8M12 17v4" />
  </svg>
</button>

<script>
  const STORAGE_KEY = 'theme';
  const MODES = ['light', 'dark', 'system'];

  const button = document.getElementById('theme-toggle');
  const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');

  function getMode() {
    return localStorage.getItem(STORAGE_KEY) || 'system';
  }

  function apply(mode: string) {
    const isDark = mode === 'dark' || (mode === 'system' && darkQuery.matches);
    document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');

    // ВАЖНО: используем атрибуты, а не свойство .hidden — оно работает на HTMLElement,
    // но SVGElement его не поддерживает в некоторых браузерах. Поэтому SVG-иконки
    // не показывались. Через setAttribute/removeAttribute работает на всех элементах.
    document.querySelectorAll('[data-theme-icon]').forEach((icon) => {
      if (icon.getAttribute('data-theme-icon') === mode) {
        icon.removeAttribute('hidden');
      } else {
        icon.setAttribute('hidden', '');
      }
    });
  }

  apply(getMode());

  button?.addEventListener('click', () => {
    const next = MODES[(MODES.indexOf(getMode()) + 1) % MODES.length];
    localStorage.setItem(STORAGE_KEY, next);
    apply(next);
  });

  darkQuery.addEventListener('change', () => {
    if (getMode() === 'system') apply('system');
  });
</script>